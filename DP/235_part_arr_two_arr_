"""
LeetCode 2035 - Partition Array Into Two Arrays to Minimize Sum Difference
Approach: Meet-in-the-middle by enumerating subset sums for each half
Time: O(n * 2^(n/2))
Space: O(2^(n/2))
"""

from bisect import bisect_left


class Solution(object):
    def minimumDifference(self, nums):
        """
        :type nums: List[int]
        :rtype: int
        """
        # Split the array into two halves so we can enumerate subset sums efficiently
        n = len(nums) // 2
        total = sum(nums)
        left = nums[:n]
        right = nums[n:]

        # left_sums[k] stores subset sums made by choosing k elements from the left half
        # right_sums[k] stores subset sums made by choosing k elements from the right half
        left_sums = [[] for _ in range(n + 1)]
        right_sums = [[] for _ in range(n + 1)]

        # Enumerate every subset of the left/right halves in lockstep
        for mask in range(1 << n):
            left_sum = 0
            right_sum = 0
            cnt = 0

            for j in range(n):
                if mask & (1 << j):
                    left_sum += left[j]
                    right_sum += right[j]
                    cnt += 1

            left_sums[cnt].append(left_sum)
            right_sums[cnt].append(right_sum)

        # Sort right-side buckets so we can binary search the closest complement
        for i in range(n + 1):
            right_sums[i].sort()

        diff = float("inf")

        # For each left bucket, find the closest right bucket sum that gets us near total/2
        for cnt in range(n + 1):
            right_bucket = right_sums[n - cnt]

            for left_sum in left_sums[cnt]:
                target = total // 2 - left_sum

                idx = bisect_left(right_bucket, target)

                if idx < len(right_bucket):
                    diff = min(diff, abs(total - 2 * (left_sum + right_bucket[idx])))

                if idx > 0:
                    diff = min(
                        diff, abs(total - 2 * (left_sum + right_bucket[idx - 1]))
                    )

        return diff
